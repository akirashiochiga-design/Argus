# Copier vers .env et renseigner la clé (jamais committée).
# Créer gratuitement une clé sur https://aistudio.google.com/app/apikey
GEMINI_API_KEY=...

# Gemini est utilisé en priorité. Modèle stable et multimodal par défaut :
# GEMINI_MODEL=gemini-2.5-flash

# Secours optionnel pour les environnements Anthropic existants :
# ANTHROPIC_API_KEY=sk-ant-...
# ARGUS_MODEL=claude-haiku-4-5
